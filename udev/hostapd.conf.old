# FieldComms WiFi Access Point configuration
# Install to: /etc/hostapd/hostapd.conf
# Works with NetworkManager or standalone hostapd

interface=wlan0
driver=nl80211
ssid=EMCOMM-NET
hw_mode=g
channel=6
ieee80211n=1
wmm_enabled=1
macaddr_acl=0
auth_algs=1
ignore_broadcast_ssid=0
wpa=2
wpa_passphrase=fieldcomms2026
wpa_key_mgmt=WPA-PSK
rsn_pairwise=CCMP

# Enable 5GHz if supported (comment out for 2.4GHz only)
# hw_mode=a
# channel=36
# ieee80211ac=1
