[Unit]
Description=FieldComms ICS Platform Server (Port 5055)
After=network.target
Wants=network.target

[Service]
Type=simple
User=fieldcomms
Group=fieldcomms
WorkingDirectory=/opt/fieldcomms
ExecStart=/opt/fieldcomms/venv/bin/python /opt/fieldcomms/python/ics_platform_server.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ics-platform

[Install]
WantedBy=multi-user.target
