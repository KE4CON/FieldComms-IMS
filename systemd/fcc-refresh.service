[Unit]
Description=FieldComms FCC Database Refresh
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=fieldcomms
Group=fieldcomms
WorkingDirectory=/opt/fieldcomms
ExecStart=/opt/fieldcomms/venv/bin/python /opt/fieldcomms/python/build_fcc_db.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fcc-refresh
